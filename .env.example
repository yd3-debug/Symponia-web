# ── Symponia Web — Environment Variables ──────────────────────────────────────

# ── Stripe (payments) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Airtable (marketing queue — used by /api/dashboard/*) ─────────────────────
# These stay server-side only (never prefixed with NEXT_PUBLIC_)
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Marketing Queue

# ── Dashboard access ───────────────────────────────────────────────────────────
# The password shown on the /dashboard login screen.
# Leave empty to disable auth (dev only).
DASHBOARD_PASSWORD=your-secret-here

# ── n8n (agent automation) ────────────────────────────────────────────────────
# Base URL of your n8n instance. Used by /api/dashboard/generate to trigger agents.
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook
