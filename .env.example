# ── Symponia Marketing Team — Environment Variables ───────────────────────────

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable ───────────────────────────────────────────────────────────────────
# Base ID: open your base in browser → airtable.com/appXXXXXXXX/...
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Marketing Queue

# ── Kie.ai ─────────────────────────────────────────────────────────────────────
# Get your API key from: https://kie.ai (dashboard → API)
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai/v1

# ── Blotato ────────────────────────────────────────────────────────────────────
# Get your API key from: https://app.blotato.com (settings → API)
BLOTATO_API_KEY=
BLOTATO_BASE_URL=https://api.blotato.com/v1

# Account IDs — find these in your Blotato connected accounts dashboard
BLOTATO_INSTAGRAM_ACCOUNT_ID=
BLOTATO_TIKTOK_ACCOUNT_ID=
BLOTATO_LINKEDIN_ACCOUNT_ID=

# ── n8n (self-hosted or cloud) ─────────────────────────────────────────────────
# The webhook base URL exposed by your n8n instance
# Used by the dashboard to trigger agents and schedule posts
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook

# ── Dashboard (symponia.io/dashboard) ─────────────────────────────────────────
# Must match DASHBOARD_PASSWORD in symponia-web/.env.local
DASHBOARD_PASSWORD=your-secret-here
